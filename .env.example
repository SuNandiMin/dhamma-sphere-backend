APP_NAME="Dhamma Sphere"
APP_ENV=local
APP_TIMEZONE=Asia/Yangon
# Required: run `php artisan key:generate` after copying to .env (Passport and encryption need it).
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dhamma-sphere
DB_USERNAME=root
DB_PASSWORD=sunandimin

BCRYPT_ROUNDS=12

CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
